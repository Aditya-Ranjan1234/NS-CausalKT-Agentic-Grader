{
  "version": 2,
  "builds": [
    {
      "src": "agentic_ui/**",
      "use": "@vercel/static"
    },
    {
      "src": "Graph/**",
      "use": "@vercel/static"
    },
    {
      "src": "api/dashboard.py",
      "use": "@vercel/python"
    },
    {
      "src": "api/causal.py",
      "use": "@vercel/python"
    },
    {
      "src": "api/analyze.py",
      "use": "@vercel/python"
    },
    {
      "src": "api/tutor.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/",
      "dest": "agentic_ui/index.html"
    },
    {
      "src": "/dashboard",
      "dest": "agentic_ui/dashboard.html"
    },
    {
      "src": "/dashboard.html",
      "dest": "agentic_ui/dashboard.html"
    },
    {
      "src": "/causal",
      "dest": "agentic_ui/causal.html"
    },
    {
      "src": "/causal.html",
      "dest": "agentic_ui/causal.html"
    },
    {
      "src": "/inference",
      "dest": "agentic_ui/inference.html"
    },
    {
      "src": "/inference.html",
      "dest": "agentic_ui/inference.html"
    },
    {
      "src": "/qanswer",
      "dest": "agentic_ui/qanswer.html"
    },
    {
      "src": "/qanswer.html",
      "dest": "agentic_ui/qanswer.html"
    },
    {
      "src": "/tutor",
      "dest": "agentic_ui/tutor.html"
    },
    {
      "src": "/tutor.html",
      "dest": "agentic_ui/tutor.html"
    },
    {
      "src": "/css/(.*)",
      "dest": "agentic_ui/css/$1"
    },
    {
      "src": "/js/(.*)",
      "dest": "agentic_ui/js/$1"
    },
    {
      "src": "/api/graphs/(.*)",
      "dest": "Graph/$1/knowledge_graph.json"
    },
    {
      "src": "/api/tutor/(.*)",
      "dest": "api/tutor.py"
    },
    {
      "src": "/api/dashboard",
      "dest": "api/dashboard.py"
    },
    {
      "src": "/api/causal",
      "dest": "api/causal.py"
    },
    {
      "src": "/api/analyze",
      "dest": "api/analyze.py"
    }
  ]
}
